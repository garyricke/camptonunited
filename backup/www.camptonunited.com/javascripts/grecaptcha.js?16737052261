var queuedRecaptchas = [] // used incase renderRecaptcha is called before recaptchaOnloadCallback
var recaptchaWidgets = []
var recaptchaLoaded = false

var renderRecaptcha = function(id) {
  var recaptchaWidget = grecaptcha.render(id, {
    'sitekey' : recaptchaSiteKey,
    'theme' : 'light'
  })
  recaptchaWidgets[id] = recaptchaWidget
}

var resetRecaptcha = function(id) {
  if(recaptchaWidgets[id] != undefined) grecaptcha.reset(recaptchaWidgets[id])
}

var initiateRecaptcha = function(id) {
  if (recaptchaLoaded) renderRecaptcha(id)
  else queuedRecaptchas.push(id)
}

var recaptchaOnloadCallback = function() {
  recaptchaLoaded = true
  for (var i = 0; i < queuedRecaptchas.length; i++) {
    renderRecaptcha(queuedRecaptchas[i])
  }
  queuedRecaptchas = []
}
